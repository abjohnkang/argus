# Docker build context exclusions for the api/Dockerfile build.
# Goal: ship only api/ source + api/requirements.txt into the image.

# VCS / orchestration metadata — never needed at runtime
.git/
.moai/
.claude/

# Project-level docs
*.md

# Python build / cache artifacts
__pycache__/
*.pyc
.venv/
.pytest_cache/
.ruff_cache/

# Frontend host artifacts (SPEC-UI-001). The web-build Dockerfile stage runs
# `npm ci` and `npm run build` fresh INSIDE the image, so a stale host
# node_modules/ or dist/ must NOT be copied into the build context. The
# web/ source itself (web/src, web/package.json, web/package-lock.json) is
# deliberately NOT excluded — the build stage needs it.
web/node_modules/
web/dist/

# Coverage artifacts (host-side tooling)
htmlcov/
.coverage

# Tests are not shipped in the runtime image (TASK-013 contract)
api/tests/
tests/

# Entry scripts and sourced helpers run on the host, not inside the container
run_*.sh
_docker_preflight.sh
_model_entrypoint.sh

# Local secrets / logs
.env
*.log
