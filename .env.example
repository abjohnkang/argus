# Argus runtime environment — copy to .env and edit. The real .env is
# gitignored (see .gitignore). REQ-INFRA-004: changing MODEL is the only
# supported way to swap models. No source-file edits required.

# The Ollama model tag to pull and serve. Default is Llama 4 Scout
# (~32-67 GB at Q4 — see .moai/specs/SPEC-INFRA-001/research.md §1).
# Smaller hardware: override to a Llama 3.x tag, e.g.:
#   MODEL=llama3.2:3b      # ~2 GB, runs on 8 GB unified memory
#   MODEL=llama3.2:1b      # smallest viable, used by the integration test
MODEL=llama4:scout

# Host port the API binds on the loopback interface. Docker maps this as
# 127.0.0.1:${API_PORT}:8000 in docker-compose.yml. Change ONLY if 8000 is
# already in use on the host (Acceptance edge case 2).
API_PORT=8000

# Internal Docker DNS name + port for the Ollama service. Used by the api
# container to reach the model container over the internal Docker network.
# Do NOT change unless the docker-compose.yml service name changes.
OLLAMA_HOST=http://model:11434
